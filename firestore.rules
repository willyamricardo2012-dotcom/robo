rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "willyamricardo2012@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function hasProductAccess(productId) {
      return isAuthenticated() && (
        isAdmin() || 
        exists(/databases/$(database)/documents/user_access/$(request.auth.uid)/products/$(productId))
      );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'type', 'content', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             data.type is string &&
             data.content is string && data.content.size() < 100000 &&
             data.createdAt is timestamp;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['role', 'text', 'timestamp']) &&
             data.role in ['user', 'model'] &&
             data.text is string && data.text.size() < 10000 &&
             data.timestamp is timestamp;
    }

    function isValidSellerConfig(data) {
      let requiredFields = ['userId', 'productName', 'productPrice', 'productLink', 'productDescription', 'isActive'];
      return data.keys().hasAll(requiredFields) &&
             data.userId == request.auth.uid &&
             data.productName is string && data.productName.size() < 200 &&
             data.productPrice is string && data.productPrice.size() < 50 &&
             data.productLink is string && data.productLink.size() < 1000 &&
             data.productDescription is string && data.productDescription.size() < 5000 &&
             (!('personality' in data) || data.personality is string) &&
             (!('knowledgeBase' in data) || data.knowledgeBase is string) &&
             data.isActive is bool &&
             (!('isAutoMode' in data) || data.isAutoMode is bool) &&
             (!('followUpSettings' in data) || (
               data.followUpSettings is map &&
               data.followUpSettings.get('delay5m', true) is bool &&
               data.followUpSettings.get('delay1h', true) is bool &&
               data.followUpSettings.get('delay24h', true) is bool
             )) &&
             (!('errors' in data) || data.errors is list) &&
             (!('stats' in data) || (
               data.stats is map &&
               data.stats.keys().hasAll(['conversations', 'sales', 'conversionRate']) &&
               data.stats.conversations is int &&
               data.stats.sales is int &&
               data.stats.conversionRate is number
             )) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'type', 'content', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.type in ['message', 'bot_response', 'sale_attempt', 'error', 'follow_up', 'payment'] &&
             data.content is string &&
             data.timestamp is timestamp;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['userId', 'amount', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.status in ['pending', 'approved', 'rejected', 'cancelled'] &&
             data.createdAt is timestamp;
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['userId', 'plan', 'status']) &&
             data.userId == request.auth.uid &&
             data.plan in ['free', 'pro'] &&
             data.status in ['active', 'expired', 'cancelled'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string);
    }

    function isValidBotConfig(data) {
      return data.keys().hasAll(['status', 'autoMode', 'sellerMode']) &&
             data.status in ['on', 'off'] &&
             data.autoMode is bool &&
             data.sellerMode is bool &&
             (!('botToken' in data) || data.botToken is string);
    }

    function isValidCoupon(data) {
      return data.keys().hasAll(['code', 'discount', 'createdAt']) &&
             data.code is string && data.code.size() > 0 &&
             data.discount is int && data.discount >= 0 && data.discount <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidIntegrations(data) {
      // Basic check for integrations map
      return data is map;
    }

    function isValidMemberProduct(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidModule(data) {
      return data.keys().hasAll(['title', 'order']) &&
             data.title is string && data.title.size() > 0 &&
             data.order is int;
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['title', 'type', 'order']) &&
             data.title is string && data.title.size() > 0 &&
             data.type in ['video', 'pdf', 'text', 'link'] &&
             data.order is int;
    }

    function isValidUserAccess(data) {
      return data.keys().hasAll(['userId', 'productId', 'purchasedAt']) &&
             data.userId is string &&
             data.productId is string &&
             data.purchasedAt is timestamp;
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['userId', 'productId', 'completedLessons']) &&
             data.userId == request.auth.uid &&
             data.productId is string &&
             data.completedLessons is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /projects/{projectId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProject(request.resource.data);
        allow update: if isOwner(userId) && isValidProject(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /chats/{chatId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChat(request.resource.data);
        allow update: if isOwner(userId) && isValidChat(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidLog(request.resource.data);
      }

      match /payments/{paymentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPayment(request.resource.data);
        allow update: if isOwner(userId) && isValidPayment(request.resource.data);
      }

      match /coupons/{couponId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCoupon(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubscription(request.resource.data);
      allow update: if isOwner(userId) && isValidSubscription(request.resource.data);
    }

    match /seller_configs/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSellerConfig(request.resource.data);
      allow update: if isOwner(userId) && isValidSellerConfig(request.resource.data);
    }

    match /bot_configs/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidBotConfig(request.resource.data);
      allow update: if isOwner(userId) && isValidBotConfig(request.resource.data);
    }

    match /integrations/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidIntegrations(request.resource.data);
      allow update: if isOwner(userId) && isValidIntegrations(request.resource.data);
    }

    match /member_products/{productId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      allow write: if isAdmin() && isValidMemberProduct(request.resource.data);

      match /modules/{moduleId} {
        allow read: if hasProductAccess(productId);
        allow list: if hasProductAccess(productId);
        allow write: if isAdmin() && isValidModule(request.resource.data);

        match /lessons/{lessonId} {
          allow read: if hasProductAccess(productId);
          allow list: if hasProductAccess(productId);
          allow write: if isAdmin() && isValidLesson(request.resource.data);
        }
      }
    }

    match /user_access/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      
      match /products/{productId} {
        allow read: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow write: if isAdmin() && isValidUserAccess(request.resource.data);
      }
    }

    match /user_progress/{userId} {
      allow read: if isOwner(userId);
      allow list: if isOwner(userId);

      match /products/{productId} {
        allow read: if isOwner(userId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId) && isValidUserProgress(request.resource.data);
      }
    }
  }
}
